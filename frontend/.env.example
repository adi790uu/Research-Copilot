# In dev, the Vite proxy forwards /api/* to localhost:8000.
# Leave VITE_API_BASE_URL unset for that to work. Override only for prod builds.
# VITE_API_BASE_URL=http://localhost:8000

# Clerk — grab the publishable key from https://dashboard.clerk.com
# (free dev instance). The matching backend secret goes in backend/.env.
VITE_CLERK_PUBLISHABLE_KEY=
