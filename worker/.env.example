# Postgres — the SAME instance research-copilot/backend uses (shared tables)
DATABASE_URL=postgresql://researchcopilot:researchcopilot@localhost:5432/research_copilot

# LLM (OpenAI-compatible). OPENAI_BASE_URL is optional (omit for api.openai.com).
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=
OPENAI_MODEL=gpt-4o-mini

# Web search
TAVILY_API_KEY=tvly-...
TAVILY_SEARCH_DEPTH=advanced

# Trigger.dev project ref (from dashboard)
TRIGGER_PROJECT_REF=proj_...
