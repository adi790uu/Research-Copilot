# LLM + Search providers
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
TAVILY_API_KEY=

# Auth — grab from https://dashboard.clerk.com (free dev instance)
# Backend verifies session JWTs against Clerk's JWKS using the secret key.
CLERK_SECRET_KEY=
CLERK_PUBLISHABLE_KEY=

# Postgres (used by SQLAlchemy app tables AND the LangGraph checkpointer).
# Canonical psycopg form — SQLAlchemy adds the +asyncpg driver internally.
# For docker compose, host is `postgres`. For local dev with the bundled
# postgres container, host is `localhost`.
DATABASE_URL=postgresql://researchcopilot:researchcopilot@localhost:5432/research_copilot

# App
LOG_LEVEL=INFO
CORS_ORIGINS=http://localhost:5173

# Workflow
WORKFLOW_MAX_ATTEMPTS=2
WORKFLOW_SEARCH_RESULTS_PER_QUERY=5
